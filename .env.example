# WordPress REST API (import mode)
MD2WP_WORDPRESS_URL=https://yourwordpresssite.com/wp-json/wp/v2
MD2WP_WORDPRESS_USERNAME=your_username
MD2WP_WORDPRESS_PASSWORD=your_application_password

# Import settings
MD2WP_SOURCE=/path/to/markdown/files
MD2WP_MODE=markdown
MD2WP_STATUS=draft

# Export settings (export mode)
MD2WP_EXPORT_OUTPUT=/path/to/export/exported_posts.xml
DOMAIN=https://yourwordpresssite.com

# Legacy env vars (still supported)
# WORDPRESS_URL=...
# USERNAME=...
# PASSWORD=...
# MARKDOWN_DIRECTORY=...
# HUGO_BUILD_DIRECTORY=...
# MARKDOWN_PARSER=normal|hugo_build
# EXPORT_MODE=import|export
# EXPORT_DIRECTORY=...
